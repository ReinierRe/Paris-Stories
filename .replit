entrypoint = "README.md"
modules = ["nodejs-22", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "gce"
build = ["npm", "run", "server:build"]
run = ["node", "server_dist/index.js"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_anthropic_ai_integrations:2.0.0", "elevenlabs:1.0.0", "javascript_object_storage:2.0.0"]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 5000

[userenv]

[userenv.shared]
EXPO_PUBLIC_FIREBASE_API_KEY = "${FIREBASE_API_KEY}"
EXPO_PUBLIC_FIREBASE_PROJECT_ID = "${FIREBASE_PROJECT_ID}"
EXPO_PUBLIC_FIREBASE_APP_ID = "${FIREBASE_APP_ID}"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
